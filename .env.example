# Free Crypto News API - Environment Variables
# Copy this file to .env.local and fill in your values

# ═══════════════════════════════════════════════════════════════
# TRANSLATION (Optional but FREE!)
# ═══════════════════════════════════════════════════════════════

# Enable real-time translation (disabled by default)
FEATURE_TRANSLATION=true

# Groq API Key - FREE! Get yours at https://console.groq.com/keys
# Uses Llama 3.3 70B for fast, high-quality translations
GROQ_API_KEY=gsk_your_groq_api_key_here

# ═══════════════════════════════════════════════════════════════
# SOCIAL INTELLIGENCE (Optional)
# ═══════════════════════════════════════════════════════════════

# Discord Bot Token - For monitoring public crypto channels
# Create a bot at https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Comma-separated Discord channel IDs to monitor
# DISCORD_CHANNEL_IDS=123456789,987654321

# Telegram Bot Token - For monitoring public crypto groups
# Create a bot via @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated Telegram chat IDs to monitor
# TELEGRAM_CHAT_IDS=-1001234567890,-1009876543210

# LunarCrush API Key - Social metrics and Galaxy Score
# Get free tier at https://lunarcrush.com/developers
# LUNARCRUSH_API_KEY=your_lunarcrush_api_key_here

# Santiment API Key - On-chain social metrics
# Get free tier at https://app.santiment.net/
# SANTIMENT_API_KEY=your_santiment_api_key_here

# ═══════════════════════════════════════════════════════════════
# API KEY MANAGEMENT (Optional)
# ═══════════════════════════════════════════════════════════════

# Vercel KV for API key storage (automatically set in Vercel)
# KV_REST_API_URL=your_kv_url_here
# KV_REST_API_TOKEN=your_kv_token_here

# Admin token for managing API keys
# ADMIN_TOKEN=your_secure_admin_token_here

# ═══════════════════════════════════════════════════════════════
# ARCHIVE SYSTEM (Optional - works without any config!)
# ═══════════════════════════════════════════════════════════════

# Protect archive endpoints with a secret (optional)
# If not set, /api/cron/archive is PUBLIC - great for testing!
# CRON_SECRET=your_secure_secret_here

# Auto-commit archives to GitHub (optional)
# Create token at: https://github.com/settings/tokens
# Needs 'repo' scope for private repos, 'public_repo' for public
# GITHUB_TOKEN=ghp_your_token_here

# ═══════════════════════════════════════════════════════════════
# x402 MICROPAYMENTS (Optional)
# ═══════════════════════════════════════════════════════════════

# Enable x402 premium features
# X402_ENABLED=true

# Your receiving wallet address (for collecting payments)
# X402_WALLET_ADDRESS=0xYourWalletAddress

# Network: 'base' for mainnet, 'base-sepolia' for testnet
# X402_NETWORK=base-sepolia

# ═══════════════════════════════════════════════════════════════
# OPTIONAL SETTINGS
# ═══════════════════════════════════════════════════════════════
# X/TWITTER SENTIMENT (No API Key Needed!)
# ═══════════════════════════════════════════════════════════════

# Uses Nitter RSS feeds - completely free, no auth required!
# Optionally configure webhooks for automated alerts:

# Discord webhook for sentiment alerts
# Create at: Server Settings > Integrations > Webhooks
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Slack webhook for sentiment alerts  
# Create at: https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Telegram bot for sentiment alerts
# Create bot via @BotFather, add to a channel, get chat ID
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=-1001234567890

# ═══════════════════════════════════════════════════════════════
# OPTIONAL SETTINGS
# ═══════════════════════════════════════════════════════════════

# Rate limiting (requests per minute, default: 60)
# RATE_LIMIT_MAX=60

# Cache TTL in seconds (default: 300 = 5 minutes)
# CACHE_TTL=300

