{
  "annotations": { "list": [] },
  "description": "Free Crypto News — Production Monitoring Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(api_requests_total[5m])",
          "legendFormat": "{{endpoint}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Latency Percentiles (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(api_latency_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(api_latency_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(api_latency_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Cache Hit Rate",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(cache_hits_total{result=\"hit\"}[5m])) / sum(rate(cache_hits_total[5m])) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 70 }
            ]
          }
        }
      }
    },
    {
      "title": "Error Rate (%)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(api_errors_total[5m])) / sum(rate(api_requests_total[5m])) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "Provider Health",
      "type": "table",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "provider_latency_ms",
          "legendFormat": "{{provider}}",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "title": "AI Inference Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "rate(ai_inferences_total[5m])",
          "legendFormat": "{{model}}"
        },
        {
          "expr": "rate(ai_tokens_total[5m])",
          "legendFormat": "tokens/s {{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 }
        }
      }
    },
    {
      "title": "WebSocket Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "ws_connections_total",
          "legendFormat": "{{instance}}"
        },
        {
          "expr": "rate(ws_messages_sent_total[5m])",
          "legendFormat": "msg/s {{channel}}"
        }
      ]
    },
    {
      "title": "Rate Limiting",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "rate(rate_limit_blocked_total[5m])",
          "legendFormat": "blocked {{tier}}"
        },
        {
          "expr": "rate(api_requests_total[5m])",
          "legendFormat": "requests {{tier}}"
        }
      ]
    },
    {
      "title": "Error Budget (30-day SLO 99.9%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [
        {
          "expr": "1 - (sum(rate(api_errors_total[30d])) / sum(rate(api_requests_total[30d])))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0.99,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0.99 },
              { "color": "yellow", "value": 0.999 },
              { "color": "green", "value": 0.9995 }
            ]
          }
        }
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["crypto", "api", "production"],
  "templating": {
    "list": [
      {
        "name": "endpoint",
        "type": "query",
        "query": "label_values(api_requests_total, endpoint)",
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "Free Crypto News — Production",
  "uid": "fcn-production",
  "version": 1
}
