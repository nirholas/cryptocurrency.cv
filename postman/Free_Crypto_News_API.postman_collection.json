{
  "info": {
    "_postman_id": "free-crypto-news-api-v2",
    "name": "Free Crypto News API",
    "description": "🆓 100% FREE crypto news API — real-time aggregator for Bitcoin, Ethereum, DeFi, Solana & altcoins.\n\nNo API key required for public endpoints.\nAggregates news from 75+ sources across 18 languages.\n\nBase URL: https://cryptocurrency.cv/api\nGitHub: https://github.com/nirholas/free-crypto-news\nDocs: https://cryptocurrency.cv/docs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://cryptocurrency.cv", "type": "string" },
    { "key": "apiKey", "value": "", "type": "string", "description": "Optional API key for authenticated endpoints" }
  ],
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Status code is 200', function () {",
          "    pm.response.to.have.status(200);",
          "});",
          "pm.test('Response time is acceptable', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(10000);",
          "});",
          "pm.test('Content-Type is present', function () {",
          "    pm.response.to.have.header('Content-Type');",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "News",
      "description": "Core news endpoints — fetch, search, filter, and discover crypto news from 75+ sources.",
      "item": [
        {
          "name": "Get Latest News",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/news?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "news"],
              "query": [
                { "key": "limit", "value": "10", "description": "Number of articles (max 100)" },
                { "key": "category", "value": "bitcoin", "description": "Filter by category", "disabled": true },
                { "key": "source", "value": "coindesk", "description": "Filter by source", "disabled": true }
              ]
            },
            "description": "Fetch the latest aggregated crypto news from 75+ sources."
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const json = pm.response.json();",
            "pm.test('Has articles array', () => pm.expect(json.articles || json).to.be.an('array'));"
          ]}}]
        },
        {
          "name": "Search News",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/search?q=ethereum&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "search"],
              "query": [
                { "key": "q", "value": "ethereum", "description": "Search query" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Full-text search across all news articles."
          }
        },
        {
