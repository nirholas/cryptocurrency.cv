{
  "name": "free-crypto-news",
  "version": "1.0.0",
  "description": "🆓 100% FREE crypto news API.  No API keys.  No rate limits. No BS.",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:a11y": "eslint src/components/*.tsx src/app/**/*.tsx",
    "lint:css": "stylelint src/**/*.css",
    "audit:contrast": "node scripts/contrast-audit.js",
    "audit:a11y": "pa11y https://free-crypto-news.vercel.app",
    "audit:unused": "knip",
    "pwa:icons": "node scripts/generate-pwa-icons.js",
    "mcp:install": "cd mcp && npm install",
    "mcp:start": "cd mcp && npm start",
    "mcp:http": "cd mcp && npm run start:http",
    "mcp:dev": "cd mcp && npm run dev",
    "i18n:translate": "node scripts/i18n/translate.js",
    "i18n:validate": "node scripts/i18n/validate.js",
    "archive:collect": "node scripts/archive/collect.js",
    "archive:enhanced": "node scripts/archive/collect-enhanced.js",
    "archive:migrate": "node scripts/archive/migrate.js",
    "archive:stats": "node scripts/archive/stats.js"
  },
  "keywords": [
    "crypto",
    "news",
    "api",
    "bitcoin",
    "defi",
    "free",
    "rss",
    "aggregator",
    "pwa"
  ],
  "author": "nirholas",
  "license": "MIT",
  "dependencies": {
    "next": "^16.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sanitize-html": "^2.17.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.11.0",
    "@eslint/eslintrc": "^3.3.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.0.9",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.13.0",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "lighthouse": "^13.0.1",
    "pa11y": "^9.0.1",
    "postcss": "^8.4.31",
    "stylelint": "^17.0.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
