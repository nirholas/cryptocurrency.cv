{
  "name": "free-crypto-news",
  "version": "1.0.2",
  "description": "Real-time crypto news aggregator with AI analysis, 12+ sources, sentiment tracking, and full market data. Works with Claude, ChatGPT, Discord, Telegram & more.",
  "private": false,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "lint:a11y": "eslint src/components/*.tsx src/app/**/*.tsx",
    "lint:css": "stylelint src/**/*.css",
    "test:a11y": "playwright test e2e/accessibility.spec.ts",
    "test:a11y:headed": "playwright test e2e/accessibility.spec.ts --headed",
    "audit:a11y": "npx pa11y https://cryptocurrency.cv",
    "audit:a11y:local": "node scripts/a11y-audit.js http://localhost:3000",
    "audit:a11y:prod": "node scripts/a11y-audit.js https://cryptocurrency.cv",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "audit:contrast": "node scripts/contrast-audit.js",
    "audit:unused": "npx knip",
    "audit:deps": "npm audit",
    "audit:secrets": "secretlint \"**/*\"",
    "audit:security": "npm audit && secretlint \"**/*\"",
    "pwa:icons": "node scripts/generate-pwa-icons.js",
    "mcp:install": "cd mcp && npm install",
    "mcp:start": "cd mcp && npm start",
    "mcp:http": "cd mcp && npm run start:http",
    "mcp:dev": "cd mcp && npm run dev",
    "i18n:translate": "npx tsx scripts/i18n/translate.ts",
    "i18n:validate": "npx tsx scripts/i18n/validate.ts",
    "i18n:check": "node scripts/i18n-check.js",
    "i18n:check:fix": "node scripts/i18n-check.js --fix --verbose",
    "i18n:watch": "npx tsx scripts/i18n/watch.ts",
    "docs:translate": "node scripts/translate-docs.js",
    "docs:translate:api": "node scripts/translate-docs.js --file docs/API.md --locales zh-CN,es,de,ja,ko",
    "archive:collect": "node scripts/archive/collect.js",
    "archive:enhanced": "node scripts/archive/collect-enhanced.js",
    "archive:migrate": "node scripts/archive/migrate.js",
    "archive:stats": "node scripts/archive/stats.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:import": "npx tsx scripts/db/import-archive.ts",
    "db:import:articles": "npx tsx scripts/db/import-archive.ts --articles",
    "db:import:market": "npx tsx scripts/db/import-archive.ts --market",
    "db:import:tags": "npx tsx scripts/db/import-archive.ts --tags",
    "db:import:predictions": "npx tsx scripts/db/import-archive.ts --predictions",
    "score:tags": "node scripts/compute-tag-scores.js",
    "enrich:archive": "node scripts/enrich-archive.js",
    "translate:archive": "node scripts/translate-archive.js",
    "translate:archive:zh": "node scripts/translate-archive.js --locale zh-CN",
    "rag:ingest": "npx tsx scripts/rag/ingest-news.ts",
    "rag:ingest:recent": "npx tsx scripts/rag/ingest-news.ts --days 30",
    "rag:ingest:clear": "npx tsx scripts/rag/ingest-news.ts --clear",
    "index:embeddings": "node scripts/index-embeddings.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "audit:ui": "playwright test e2e/ui-audit.spec.ts --project=chromium",
    "audit:ui:headed": "playwright test e2e/ui-audit.spec.ts --project=chromium --headed",
    "analyze": "ANALYZE=true next build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "docs:install": "pip install -r docs/requirements.txt",
    "docs:dev": "mkdocs serve -a localhost:8000",
    "docs:build": "mkdocs build",
    "docs:deploy": "mkdocs gh-deploy --force",
    "prepare": "husky",
    "postinstall": "node -e \"const fs=require('fs');const p='node_modules/tsconfig.base.json';if(!fs.existsSync(p))fs.writeFileSync(p,JSON.stringify({compilerOptions:{strict:true,esModuleInterop:true,skipLibCheck:true,moduleResolution:'bundler',module:'esnext',target:'es2021',lib:['es2021','dom']}},null,2))\""
  },
  "keywords": [
    "crypto",
    "news",
    "api",
    "bitcoin",
    "defi",
    "free",
    "rss",
    "aggregator",
    "pwa"
  ],
  "author": "nirholas",
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@heroicons/react": "^2.2.0",
    "@neondatabase/serverless": "^1.0.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.212.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/resources": "^2.5.1",
    "@opentelemetry/sdk-metrics": "^2.5.1",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/recharts": "^2.0.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "@vercel/analytics": "^1.6.1",
    "@vercel/kv": "^3.0.0",
    "@vercel/speed-insights": "^1.3.1",
    "@x402/core": "^2.4.0",
    "@x402/evm": "^2.4.0",
    "@x402/next": "^2.4.0",
    "dompurify": "^3.3.1",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.34.3",
    "gray-matter": "^4.0.3",
    "inngest": "^3.52.3",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "next-intl": "^4.8.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reading-time": "^1.5.0",
    "recharts": "^3.7.0",
    "redis": "^5.11.0",
    "sanitize-html": "^2.17.1",
    "swagger-ui-react": "^5.31.2",
    "swr": "^2.4.0",
    "web-vitals": "^5.1.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.11.1",
    "@axe-core/playwright": "^4.11.1",
    "@eslint/eslintrc": "^0.1.0",
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@secretlint/secretlint-rule-preset-recommend": "^11.3.1",
    "@storybook/addon-a11y": "^10.2.10",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^10.2.10",
    "@storybook/nextjs": "^10.2.10",
    "@storybook/react": "^10.2.10",
    "@tailwindcss/postcss": "^4.2.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/redis": "^4.0.11",
    "@types/sanitize-html": "^2.16.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@typescript-eslint/scope-manager": "^8.56.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/ui": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.1",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lighthouse": "^12.6.1",
    "lint-staged": "^16.2.7",
    "pa11y": "^9.1.0",
    "postcss": "^8.5.6",
    "secretlint": "^11.3.1",
    "sharp": "^0.34.5",
    "storybook": "^10.2.10",
    "stylelint": "^17.3.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "bn.js": "^5.2.3",
    "elliptic": "^6.6.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
